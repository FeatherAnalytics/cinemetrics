# Copy to .env and fill in. .env is gitignored.

# TMDB API — https://www.themoviedb.org/settings/api
# Used to enrich films (genres, keywords, runtime, budget, revenue) by id.
TMDB_API_KEY=your_key_here

# OMDb API — https://www.omdbapi.com/apikey.aspx
# Used to enrich films (Metascore, Rotten Tomatoes, IMDb, box office, cast) by imdb id.
OMDB_API_KEY=your_key_here

# Letterboxd username, for the RSS feed the updater reads.
LETTERBOXD_USER=poopascoopa

# Cloudflare R2 — used to store ML embeddings for the recommendation engine.
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=cinemetrics-ml

# R2 public URL for the embeddings bucket (used by the web app).
NEXT_PUBLIC_R2_URL=https://your-r2-public-url.r2.dev
