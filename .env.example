# Copy to .env and fill in. .env is gitignored.

# TMDB API — https://www.themoviedb.org/settings/api
# Used to enrich films (genres, keywords, runtime, budget, revenue) by id.
TMDB_API_KEY=your_key_here

# OMDb API — https://www.omdbapi.com/apikey.aspx
# Used to enrich films (Metascore, Rotten Tomatoes, IMDb, box office, cast) by imdb id.
OMDB_API_KEY=your_key_here

# Letterboxd username, for the RSS feed the updater reads.
LETTERBOXD_USER=your_letterboxd_username
